{
  "manifest_version": 3,
  "name": "AI Quota Guard Bridge",
  "version": "1.1.0",
  "description": "将 claude.ai 订阅用量数据同步给 AI Quota Guard 工具",

  "permissions": [
    "storage",
    "alarms",
    "nativeMessaging"
  ],

  "host_permissions": [
    "https://claude.ai/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://claude.ai/settings/usage*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Quota Guard"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
